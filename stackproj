#!/usr/bin/env python3
"""
stackproj - Feature branch management for git repos with submodules

Usage:
    stackproj create <feature>     Create a new feature branch in superproject
    stackproj add <submodule>      Add submodule to current feature
    stackproj switch <feature>     Switch to a different feature (all submodules)
    stackproj status               Show current feature and its submodules
    stackproj list                 List all features
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

import yaml

STACK_FILE = ".stackproj.yml"


def get_project_root():
    """Find the project root (where .stackproj.yml lives)."""
    cwd = Path.cwd()
    while cwd != cwd.parent:
        if (cwd / STACK_FILE).exists():
            return cwd
        cwd = cwd.parent
    # Not found in parents - create in current dir
    return Path.cwd()


def run(cmd, cwd=None, check=True):
    """Run a shell command."""
    result = subprocess.run(cmd, shell=True, cwd=cwd, capture_output=True, text=True)
    if check and result.returncode != 0:
        print(f"Error: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return result


def load_stack():
    """Load the stack file."""
    root = get_project_root()
    stack_file = root / STACK_FILE
    if stack_file.exists():
        with open(stack_file) as f:
            data = yaml.safe_load(f)
            if data:
                return data
    # Create new if doesn't exist
    data = {"current": None, "features": {}}
    save_stack(data, root)
    print(f"Created {STACK_FILE} in {root}")
    return data


def save_stack(data, root=None):
    """Save the stack file."""
    if root is None:
        root = get_project_root()
    stack_file = root / STACK_FILE
    with open(stack_file, "w") as f:
        yaml.dump(data, f, default_flow_style=False)


def cmd_create(args):
    """Create a new feature branch."""
    stack = load_stack()
    feature = args.feature

    if feature in stack["features"]:
        print(f"Feature '{feature}' already exists")
        sys.exit(1)

    # Get current branch to fork from
    result = run("git rev-parse --abbrev-ref HEAD", check=False)
    base_branch = result.stdout.strip() if result.returncode == 0 else "main"

    # Create branch in superproject only
    run(f"git checkout -b {feature}")

    # Save to stack
    stack["features"][feature] = {
        "base": base_branch,
        "submodules": {}
    }
    stack["current"] = feature
    save_stack(stack)
    print(f"Created feature '{feature}' (forked from {base_branch})")


def cmd_add(args):
    """Add submodule(s) to the current feature."""
    stack = load_stack()
    current = stack.get("current")

    if not current:
        print("Error: No feature selected. Use 'stackproj create' first.")
        sys.exit(1)

    for submodule in args.submodules:
        if not os.path.exists(submodule):
            print(f"Error: Submodule '{submodule}' not found")
            continue

        # Create a derived branch name: feature-submodule
        submodule_branch = f"{current}-{submodule}"

        # Create branch in submodule
        result = run(f"git -C {submodule} rev-parse --abbrev-ref HEAD", check=False)
        base_branch = result.stdout.strip() if result.returncode == 0 else "main"

        run(f"git -C {submodule} checkout -b {submodule_branch}")

        # Record it
        stack["features"][current]["submodules"][submodule] = {
            "branch": submodule_branch,
            "base": base_branch
        }
        print(f"Added '{submodule}' to feature '{current}' as branch '{submodule_branch}'")

    save_stack(stack)


def cmd_switch(args):
    """Switch to a different feature."""
    stack = load_stack()
    feature = args.feature

    if feature not in stack["features"]:
        print(f"Error: Feature '{feature}' not found")
        sys.exit(1)

    # Switch superproject
    run(f"git checkout {feature}")

    # Switch each submodule
    for submodule, info in stack["features"][feature]["submodules"].items():
        branch = info["branch"]
        if os.path.exists(submodule):
            run(f"git -C {submodule} checkout {branch}")
            print(f"  {submodule}: {branch}")
        else:
            print(f"  Warning: {submodule} not found", file=sys.stderr)

    stack["current"] = feature
    save_stack(stack)
    print(f"Switched to feature '{feature}'")


def cmd_status(args):
    """Show current status."""
    stack = load_stack()
    current = stack.get("current")

    if not current:
        print("No feature selected")
        return

    print(f"Current feature: {current}")
    print("Submodules:")
    for submodule, info in stack["features"][current]["submodules"].items():
        print(f"  {submodule}: {info['branch']}")


def cmd_list(args):
    """List all features."""
    stack = load_stack()
    if not stack["features"]:
        print("No features found")
        return

    for name, info in stack["features"].items():
        marker = " *" if name == stack.get("current") else " "
        submodules = list(info["submodules"].keys())
        print(f"{marker} {name} (from {info['base']})")
        for s in submodules:
            print(f"    - {s}: {info['submodules'][s]['branch']}")


def cmd_main(args):
    """Switch back to main, detached head for all submodules."""
    stack = load_stack()

    # Switch superproject to main
    run("git checkout main")

    # Detach all submodules at their main branch HEAD
    result = run("git submodule status", check=False)
    if result.returncode == 0:
        for line in result.stdout.strip().split("\n"):
            if line:
                parts = line.split()
                if len(parts) >= 2:
                    submodule_path = parts[1]
                    # Get the commit hash from the first column
                    commit_hash = parts[0]
                    run(f"git -C {submodule_path} checkout {commit_hash}")
                    print(f"  {submodule_path}: detached at {commit_hash[:7]}")

    # Clear current
    stack["current"] = None
    save_stack(stack)
    print("Switched to main, submodules detached")


def cmd_delete(args):
    """Delete a feature and all its branches."""
    stack = load_stack()
    feature = args.feature

    if feature not in stack["features"]:
        print(f"Error: Feature '{feature}' not found")
        sys.exit(1)

    info = stack["features"][feature]
    submodules = list(info["submodules"].keys())

    # Also find any submodules with a branch matching the feature name (legacy)
    all_submodule_branches = []
    if os.path.exists(".gitmodules"):
        result = run("git submodule status", check=False)
        if result.returncode == 0:
            for line in result.stdout.strip().split("\n"):
                if line:
                    parts = line.split()
                    if len(parts) >= 2:
                        submodule_path = parts[1]
                        # Check if this submodule has a branch matching the feature
                        branch_result = run(f"git -C {submodule_path} rev-parse --abbrev-ref HEAD", check=False)
                        if branch_result.returncode == 0:
                            current_branch = branch_result.stdout.strip()
                            if current_branch == feature:
                                all_submodule_branches.append((submodule_path, feature))

    # Show what will be deleted
    print(f"Will delete feature '{feature}':")
    print(f"  - superproject branch: {feature}")
    for s in submodules:
        print(f"  - {s} branch: {info['submodules'][s]['branch']}")
    for s, b in all_submodule_branches:
        if s not in submodules:
            print(f"  - {s} branch: {b} (detected)")

    confirm = input("\nType 'yes' to confirm: ")
    if confirm != "yes":
        print("Cancelled")
        return

    # Delete superproject branch (switch to main first if needed)
    current = run("git rev-parse --abbrev-ref HEAD").stdout.strip()
    if current == feature:
        run("git checkout main")
    run(f"git branch -D {feature}", check=False)

    # Delete submodule branches (explicitly tracked)
    for s in submodules:
        if os.path.exists(s):
            run(f"git -C {s} branch -D {info['submodules'][s]['branch']}", check=False)

    # Delete any other submodules on this feature branch
    for s, b in all_submodule_branches:
        if s not in submodules and os.path.exists(s):
            # Switch away first if on that branch
            branch_result = run(f"git -C {s} rev-parse --abbrev-ref HEAD", check=False)
            if branch_result.returncode == 0 and branch_result.stdout.strip() == b:
                run(f"git -C {s} checkout main", check=False)
            run(f"git -C {s} branch -D {b}", check=False)

    # Remove from stack
    del stack["features"][feature]
    if stack.get("current") == feature:
        stack["current"] = None
    save_stack(stack)
    print(f"Deleted feature '{feature}'")


def main():
    parser = argparse.ArgumentParser(prog="stackproj")
    subparsers = parser.add_subparsers()

    p_create = subparsers.add_parser("create", help="Create a new feature")
    p_create.add_argument("feature", help="Feature name")
    p_create.set_defaults(func=cmd_create)

    p_add = subparsers.add_parser("add", help="Add submodule(s) to current feature")
    p_add.add_argument("submodules", nargs="+", help="Submodule path(s)")
    p_add.set_defaults(func=cmd_add)

    p_switch = subparsers.add_parser("switch", help="Switch to a feature")
    p_switch.add_argument("feature", help="Feature name")
    p_switch.set_defaults(func=cmd_switch)

    p_delete = subparsers.add_parser("delete", help="Delete a feature and its branches")
    p_delete.add_argument("feature", help="Feature name")
    p_delete.set_defaults(func=cmd_delete)

    subparsers.add_parser("main", help="Switch to main, detach submodules")
    subparsers.add_parser("status", help="Show current status")
    subparsers.add_parser("list", help="List all features")

    args = parser.parse_args()

    if hasattr(args, "func"):
        args.func(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()