#!/usr/bin/env python3
"""
stackproj - Feature branch management for git repos with submodules

Usage:
    stackproj create <feature>     Create a new feature branch in superproject
    stackproj add <submodule>      Add submodule to current feature
    stackproj switch <feature>     Switch to a different feature (all submodules)
    stackproj status               Show current feature and its submodules
    stackproj list                 List all features
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

import yaml

STACK_FILE = ".stackproj.yml"


def is_valid_branch_name(name):
    """Check if name is valid for git branch."""
    invalid_chars = ['~', '^', ':', '\\', ' ', '#', '[', ']']
    if any(c in name for c in invalid_chars):
        return False
    if name.startswith('.') or name.endswith('.') or name.endswith('/'):
        return False
    if '//' in name or '/.' in name or '.@' in name:
        return False
    if name in ['/', '.', '..', '@{']:
        return False
    return True


def get_git_username():
    """Get git user name for branch naming."""
    result = run("git config user.name", check=False)
    if result.returncode == 0:
        # Convert to lowercase, replace spaces with dashes
        return result.stdout.strip().lower().replace(' ', '-')
    return "unknown"


def get_project_root():
    """Find the project root (where .stackproj.yml lives)."""
    cwd = Path.cwd()
    while cwd != cwd.parent:
        if (cwd / STACK_FILE).exists():
            return cwd
        cwd = cwd.parent
    # Not found in parents - create in current dir
    return Path.cwd()


def run(cmd, cwd=None, check=True):
    """Run a shell command."""
    result = subprocess.run(cmd, shell=True, cwd=cwd, capture_output=True, text=True)
    if check and result.returncode != 0:
        print(f"Error: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return result


def load_stack():
    """Load the stack file."""
    root = get_project_root()
    stack_file = root / STACK_FILE
    if stack_file.exists():
        with open(stack_file) as f:
            data = yaml.safe_load(f)
            if data:
                return data
    # Create new if doesn't exist
    data = {"current": None, "features": {}}
    save_stack(data, root)
    print(f"Created {STACK_FILE} in {root}")
    return data


def save_stack(data, root=None):
    """Save the stack file."""
    if root is None:
        root = get_project_root()
    stack_file = root / STACK_FILE
    with open(stack_file, "w") as f:
        yaml.dump(data, f, default_flow_style=False)


def cmd_create(args):
    """Create a new feature branch."""
    stack = load_stack()
    feature = args.feature

    if feature in stack["features"]:
        print(f"Feature '{feature}' already exists")
        sys.exit(1)

    if not is_valid_branch_name(feature):
        print(f"Error: '{feature}' is not a valid branch name")
        print("Use only letters, numbers, dashes, underscores. Cannot start with dash or dot.")
        sys.exit(1)

    # Get current branch to fork from
    result = run("git rev-parse --abbrev-ref HEAD", check=False)
    base_branch = result.stdout.strip() if result.returncode == 0 else "main"

    # Create branch in superproject only
    run(f"git checkout -b {feature}")

    # Save to stack
    stack["features"][feature] = {
        "base": base_branch,
        "submodules": {}
    }
    stack["current"] = feature
    save_stack(stack)
    print(f"Created feature '{feature}' (forked from {base_branch})")


def cmd_add(args):
    """Add submodule(s) to the current feature."""
    stack = load_stack()
    current = stack.get("current")

    if not current:
        print("Error: No feature selected. Use 'stackproj create' first.")
        sys.exit(1)

    # Get git username for branch naming
    username = get_git_username()

    for submodule in args.submodules:
        if not os.path.exists(submodule):
            print(f"Error: Submodule '{submodule}' not found")
            continue

        # Create branch name: username/project/repo
        submodule_branch = f"{username}/{current}/{submodule}"

        # Create branch in submodule
        result = run(f"git -C {submodule} rev-parse --abbrev-ref HEAD", check=False)
        base_branch = result.stdout.strip() if result.returncode == 0 else "main"

        run(f"git -C {submodule} checkout -b {submodule_branch}")

        # Record it
        stack["features"][current]["submodules"][submodule] = {
            "branch": submodule_branch,
            "base": base_branch
        }
        print(f"Added '{submodule}' to feature '{current}' as branch '{submodule_branch}'")

    save_stack(stack)


def cmd_switch(args):
    """Switch to a different feature."""
    stack = load_stack()
    feature = args.feature

    if feature not in stack["features"]:
        print(f"Error: Feature '{feature}' not found")
        sys.exit(1)

    # Switch superproject
    run(f"git checkout {feature}")

    # Switch each submodule
    for submodule, info in stack["features"][feature]["submodules"].items():
        branch = info["branch"]
        if os.path.exists(submodule):
            run(f"git -C {submodule} checkout {branch}")
            print(f"  {submodule}: {branch}")
        else:
            print(f"  Warning: {submodule} not found", file=sys.stderr)

    stack["current"] = feature
    save_stack(stack)
    print(f"Switched to feature '{feature}'")


def cmd_status(args):
    """Show current status."""
    stack = load_stack()
    current = stack.get("current")

    if not current:
        print("No feature selected")
        return

    print(f"Current feature: {current}")
    print("Submodules:")
    for submodule, info in stack["features"][current]["submodules"].items():
        print(f"  {submodule}: {info['branch']}")


def cmd_list(args):
    """List all features."""
    stack = load_stack()
    if not stack["features"]:
        print("No features found")
        return

    for name, info in stack["features"].items():
        marker = " *" if name == stack.get("current") else " "
        submodules = list(info["submodules"].keys())
        print(f"{marker} {name} (from {info['base']})")
        for s in submodules:
            print(f"    - {s}: {info['submodules'][s]['branch']}")


def cmd_remove(args):
    """Remove a submodule from current feature."""
    stack = load_stack()
    current = stack.get("current")
    submodule = args.submodule

    if not current:
        print("Error: No feature selected")
        sys.exit(1)

    if current not in stack["features"]:
        print(f"Error: Feature '{current}' not found")
        sys.exit(1)

    if submodule not in stack["features"][current]["submodules"]:
        print(f"Error: Submodule '{submodule}' not in feature '{current}'")
        sys.exit(1)

    branch = stack["features"][current]["submodules"][submodule]["branch"]

    # Get recorded commit from current superproject branch
    result = run(f"git ls-tree HEAD {submodule}")
    if result.returncode == 0:
        commit_hash = result.stdout.split()[2]
        if os.path.exists(submodule):
            # Discard any local changes and checkout recorded commit
            run(f"git -C {submodule} checkout -f {commit_hash}")
            print(f"  {submodule}: detached at {commit_hash[:7]}")

            # Delete the feature branch
            run(f"git -C {submodule} branch -D {branch}", check=False)
            print(f"  {submodule}: deleted branch '{branch}'")

    # Remove from stack
    del stack["features"][current]["submodules"][submodule]
    save_stack(stack)
    print(f"Removed '{submodule}' from feature '{current}'")


def cmd_doctor(args):
    """Check for problems and optionally fix them."""
    stack = load_stack()
    fix = args.fix
    problems = []

    # Check 1: current feature set but branch doesn't exist
    current = stack.get("current")
    if current:
        result = run(f"git rev-parse --verify {current}", check=False)
        if result.returncode != 0:
            problems.append(f"Current feature '{current}' branch does not exist in superproject")

    # Check 2: tracked submodules that don't exist
    for feature, info in stack["features"].items():
        for submodule, subinfo in info["submodules"].items():
            if not os.path.exists(submodule):
                problems.append(f"Submodule '{submodule}' tracked in '{feature}' does not exist")
            else:
                # Check if branch exists
                branch = subinfo["branch"]
                result = run(f"git -C {submodule} rev-parse --verify {branch}", check=False)
                if result.returncode != 0:
                    problems.append(f"Branch '{branch}' in '{submodule}' does not exist")

    # Check 3: submodules on branches not tracked
    if os.path.exists(".gitmodules"):
        result = run("git submodule status", check=False)
        if result.returncode == 0:
            for line in result.stdout.strip().split("\n"):
                if line:
                    parts = line.split()
                    if len(parts) >= 2:
                        submodule_path = parts[1]
                        # Check if on a branch
                        branch_result = run(f"git -C {submodule_path} rev-parse --abbrev-ref HEAD", check=False)
                        if branch_result.returncode == 0:
                            current_branch = branch_result.stdout.strip()
                            if current_branch != "HEAD":
                                # Check if tracked
                                tracked = False
                                for feature, info in stack["features"].items():
                                    if submodule_path in info["submodules"]:
                                        if info["submodules"][submodule_path]["branch"] == current_branch:
                                            tracked = True
                                if not tracked:
                                    problems.append(f"Submodule '{submodule_path}' on untracked branch '{current_branch}'")

    if not problems:
        print("No problems found")
        return

    print("Problems found:")
    for p in problems:
        print(f"  - {p}")

    if fix:
        print("\nFixing...")
        # Fix 1: current feature branch doesn't exist
        if current:
            result = run(f"git rev-parse --verify {current}", check=False)
            if result.returncode != 0:
                stack["current"] = None
                print(f"  Cleared current feature '{current}'")

        # Fix 2: remove missing submodules
        for feature, info in list(stack["features"].items()):
            for submodule in list(info["submodules"].keys()):
                if not os.path.exists(submodule):
                    del stack["features"][feature]["submodules"][submodule]
                    print(f"  Removed missing submodule '{submodule}' from '{feature}'")

        # Fix 3: submodules on untracked branches - leave as warning only, don't auto-fix
        save_stack(stack)
        print("\nDone")
    else:
        print("\nRun 'stackproj doctor fix' to fix these problems")


def cmd_main(args):
    """Switch back to main, detached head for all submodules."""
    stack = load_stack()

    # Switch superproject to main
    run("git checkout main")

    # Detach all submodules at the commit recorded in superproject HEAD
    submodules = []
    result = run("git submodule status", check=False)
    for line in result.stdout.strip().split("\n"):
        if line and not line.startswith("fatal:"):
            parts = line.split()
            if len(parts) >= 2:
                submodule_path = parts[1]
                # Get the commit recorded in superproject HEAD (not current submodule state)
                recorded = run(f"git ls-tree HEAD {submodule_path}")
                if recorded.returncode == 0:
                    commit_hash = recorded.stdout.split()[2]
                    run(f"git -C {submodule_path} checkout --detach -f {commit_hash}")
                    submodules.append((submodule_path, commit_hash[:7]))

    # Print in columns
    if submodules:
        max_name = max(len(s[0]) for s in submodules)
        for name, commit in submodules:
            print(f"  {name.ljust(max_name)}  detached at {commit}")

    # Clear current
    stack["current"] = None
    save_stack(stack)
    print("Switched to main, submodules detached")


def cmd_delete(args):
    """Delete a feature and all its branches."""
    stack = load_stack()
    feature = args.feature

    if feature not in stack["features"]:
        print(f"Error: Feature '{feature}' not found")
        sys.exit(1)

    info = stack["features"][feature]
    submodules = list(info["submodules"].keys())

    # Also find any submodules with a branch matching the feature name (legacy)
    all_submodule_branches = []
    if os.path.exists(".gitmodules"):
        result = run("git submodule status", check=False)
        if result.returncode == 0:
            for line in result.stdout.strip().split("\n"):
                if line:
                    parts = line.split()
                    if len(parts) >= 2:
                        submodule_path = parts[1]
                        # Check if this submodule has a branch matching the feature
                        branch_result = run(f"git -C {submodule_path} rev-parse --abbrev-ref HEAD", check=False)
                        if branch_result.returncode == 0:
                            current_branch = branch_result.stdout.strip()
                            if current_branch == feature:
                                all_submodule_branches.append((submodule_path, feature))

    # Show what will be deleted
    print(f"Will delete feature '{feature}':")
    print(f"  - superproject branch: {feature}")
    for s in submodules:
        print(f"  - {s} branch: {info['submodules'][s]['branch']}")
    for s, b in all_submodule_branches:
        if s not in submodules:
            print(f"  - {s} branch: {b} (detected)")

    confirm = input("\nType 'yes' to confirm: ")
    if confirm != "yes":
        print("Cancelled")
        return

    # Switch superproject to main first (can't delete checked-out branch)
    current = run("git rev-parse --abbrev-ref HEAD").stdout.strip()
    if current == feature:
        run("git checkout main")

    # Switch submodules to main first, then delete branches
    for s in submodules:
        if os.path.exists(s):
            branch_result = run(f"git -C {s} rev-parse --abbrev-ref HEAD", check=False)
            if branch_result.returncode == 0 and branch_result.stdout.strip() == info['submodules'][s]['branch']:
                run(f"git -C {s} checkout main", check=False)
            run(f"git -C {s} branch -D {info['submodules'][s]['branch']}", check=False)

    for s, b in all_submodule_branches:
        if s not in submodules and os.path.exists(s):
            branch_result = run(f"git -C {s} rev-parse --abbrev-ref HEAD", check=False)
            if branch_result.returncode == 0 and branch_result.stdout.strip() == b:
                run(f"git -C {s} checkout main", check=False)
            run(f"git -C {s} branch -D {b}", check=False)

    # Now delete superproject branch
    run(f"git branch -D {feature}", check=False)

    # Remove from stack
    del stack["features"][feature]
    if stack.get("current") == feature:
        stack["current"] = None
    save_stack(stack)
    print(f"Deleted feature '{feature}'")


def main():
    parser = argparse.ArgumentParser(prog="stackproj")
    subparsers = parser.add_subparsers()

    p_create = subparsers.add_parser("create", help="Create a new feature")
    p_create.add_argument("feature", help="Feature name")
    p_create.set_defaults(func=cmd_create)

    p_add = subparsers.add_parser("add", help="Add submodule(s) to current feature")
    p_add.add_argument("submodules", nargs="+", help="Submodule path(s)")
    p_add.set_defaults(func=cmd_add)

    p_switch = subparsers.add_parser("switch", help="Switch to a feature")
    p_switch.add_argument("feature", help="Feature name")
    p_switch.set_defaults(func=cmd_switch)

    p_delete = subparsers.add_parser("delete", help="Delete a feature and its branches")
    p_delete.add_argument("feature", help="Feature name")
    p_delete.set_defaults(func=cmd_delete)

    p_remove = subparsers.add_parser("remove", help="Remove a submodule from current feature")
    p_remove.add_argument("submodule", help="Submodule path")
    p_remove.set_defaults(func=cmd_remove)

    p_doctor = subparsers.add_parser("doctor", help="Check for problems")
    p_doctor.add_argument("--fix", action="store_true", help="Fix problems")
    p_doctor.set_defaults(func=cmd_doctor)

    p_main = subparsers.add_parser("main", help="Switch to main, detach submodules")
    p_main.set_defaults(func=cmd_main)
    p_status = subparsers.add_parser("status", help="Show current status")
    p_status.set_defaults(func=cmd_status)
    p_list = subparsers.add_parser("list", help="List all features")
    p_list.set_defaults(func=cmd_list)

    args = parser.parse_args()

    if hasattr(args, "func"):
        args.func(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()